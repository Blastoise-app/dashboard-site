# Firebase Web SDK config — copy this file to .env.local and fill in real values.
# Values come from Firebase console → Project Settings → "Your apps" → Web app config.
# .env.local is gitignored. .env.example is checked in as a template.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
